}
# 创建或更新.Rbuildignore
# 注意：这个文件告诉R在构建检查时忽略某些文件，但不影响打包
cat("^.*\\.Rproj$
^\\.Rproj\\.user$
^README\\.Rmd$
^LICENSE\\.md$
^\\.git$
^\\.gitignore$
^data-raw$
", file = ".Rbuildignore")
# 注意：不要把README.md加入.Rbuildignore！
